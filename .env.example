# ⚠️ Credenciales POR ENTORNO. TRES bases, una por tier:
#   • local        → Supabase local (supabase start, 127.0.0.1). Va en tu .env.local.
#   • development  → Supabase dev remoto. Vive en Vercel (scope Preview).
#   • production   → Supabase prod. Vive en Vercel (scope Production).
# Este template es para tu .env.local (tier local). Las vars de development y
# production NO van en archivos del repo: viven en el dashboard de Vercel.
# env.client.ts rompe el build si un tier ≠ production apunta al ref de prod.

# ── Supabase (cliente) — credenciales de tu Supabase LOCAL ─────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Supabase + Resend (solo servidor) ─────────────────────────
SUPABASE_SERVICE_ROLE_KEY=eyJ...
RESEND_API_KEY=re_...

# ── Tier del entorno (NEXT_PUBLIC_: lo lee el cliente para isProdDb/badge) ──
# local | development | production
NEXT_PUBLIC_APP_ENV=local
