# ⚠️ Las credenciales son POR ENTORNO. Hay dos proyectos Supabase:
#   • PROD  → proyecto del grupo (eminat.app). Sus vars viven en Vercel.
#   • DEV   → proyecto Supabase de desarrollo (org free). Va en tu .env.local.
# En local SIEMPRE apuntá a DEV, nunca a prod. (env.client.ts rompe el build
# si APP_ENV=development apunta al ref de prod.)

# ── Supabase (cliente) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Supabase + Resend (solo servidor) ─────────────────────────
SUPABASE_SERVICE_ROLE_KEY=eyJ...
RESEND_API_KEY=re_...

# ── Contexto de despliegue ─────────────────────────────────────
# development = local (apunta a DEV) | vercel = eminat.app (PROD) | selfhosted
APP_ENV=development
